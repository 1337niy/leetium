# Maintainer: Leetium Contributors
pkgname=leetium
pkgver=0.1.0
pkgrel=1
pkgdesc="Personal AI gateway inspired by OpenClaw"
arch=('x86_64' 'aarch64')
url="https://www.leetnex.ru/"
license=('MIT')
depends=('gcc-libs')
makedepends=('cargo')

build() {
    cd "$srcdir"
    cargo build --release --manifest-path="${startdir}/../../Cargo.toml"
}

package() {
    install -Dm755 "${startdir}/../../target/release/leetium" "${pkgdir}/usr/bin/leetium"
    install -Dm644 "${startdir}/../../LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" 2>/dev/null || true
}
