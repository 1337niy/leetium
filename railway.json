{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "startCommand": "LEETIUM_CONFIG_DIR=/tmp/leetium/config LEETIUM_DATA_DIR=/tmp/leetium LEETIUM_DEPLOY_PLATFORM=railway leetium --bind 0.0.0.0 --port $PORT --no-tls",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 5,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
